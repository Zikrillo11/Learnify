@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Learnify</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background: #f4f6f9;
                font-family: 'Segoe UI', sans-serif;
            }

            .navbar {
                background: linear-gradient(90deg, #0f2027, #203a43, #2c5364);
            }

                .navbar a {
                    color: white !important;
                    margin-left: 15px;
                }

            .hero {
                background: linear-gradient(135deg, #667eea, #764ba2);
                color: white;
                padding: 100px 0;
                text-align: center;
            }

            .card-modern {
                border: none;
                border-radius: 15px;
                box-shadow: 0 8px 20px rgba(0,0,0,0.1);
                transition: 0.3s;
            }

                .card-modern:hover {
                    transform: translateY(-10px);
                }

            footer {
                background: #0f2027;
                color: white;
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand text-white fw-bold" asp-controller="Home" asp-action="Index">🚀 Learnify</a>
            <div>
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Home" asp-action="About">About</a>
                <a asp-controller="Home" asp-action="Courses">Courses</a>
                <a asp-controller="Home" asp-action="Contact">Contact</a>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="text-center p-4 mt-5">
        © 2026 Learnify | All Rights Reserved
    </footer>

</body>
</html>