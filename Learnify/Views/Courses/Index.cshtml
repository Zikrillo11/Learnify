@{
    ViewData["Title"] = "Courses";
}

<section class="py-5 text-white" style="background: linear-gradient(135deg,#141e30,#243b55);">
    <div class="container text-center py-5">
        <h1 class="display-4 fw-bold">Our Courses 📚</h1>
        <p class="lead">Professional va zamonaviy kurslar</p>
    </div>
</section>

<section class="py-5">
    <div class="container">

        <div class="row g-4">

            <!-- Course 1 -->
            <div class="col-lg-4">
                <div class="card border-0 shadow rounded-4 overflow-hidden h-100">
                    <div style="background:#1e3c72;height:120px;"></div>
                    <div class="card-body">
                        <h5 class="fw-bold">ASP.NET Core</h5>
                        <p class="text-muted">Backend development professional daraja</p>
                        <span class="badge bg-success">Advanced</span>
                    </div>
                </div>
            </div>

            <!-- Course 2 -->
            <div class="col-lg-4">
                <div class="card border-0 shadow rounded-4 overflow-hidden h-100">
                    <div style="background:#ff512f;height:120px;"></div>
                    <div class="card-body">
                        <h5 class="fw-bold">Frontend Mastery</h5>
                        <p class="text-muted">HTML, CSS, JavaScript, React</p>
                        <span class="badge bg-primary">Popular</span>
                    </div>
                </div>
            </div>

            <!-- Course 3 -->
            <div class="col-lg-4">
                <div class="card border-0 shadow rounded-4 overflow-hidden h-100">
                    <div style="background:#11998e;height:120px;"></div>
                    <div class="card-body">
                        <h5 class="fw-bold">UI/UX Design</h5>
                        <p class="text-muted">Professional design systems</p>
                        <span class="badge bg-warning text-dark">New</span>
                    </div>
                </div>
            </div>

        </div>

    </div>
</section>

<section class="py-5 bg-light text-center">
    <div class="container">
        <h3 class="fw-bold mb-4">Start Learning Today 🚀</h3>
        <a href="#" class="btn btn-primary btn-lg px-5">Join Now</a>
    </div>
</section>