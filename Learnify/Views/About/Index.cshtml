@{
    ViewData["Title"] = "About";
}

<!-- HERO -->
<section class="py-5 text-white" style="background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);">
    <div class="container text-center py-5">
        <h1 class="display-4 fw-bold mb-3">About Learnify 🚀</h1>
        <p class="lead">Zamonaviy ta'lim platformasi</p>
    </div>
</section>

<!-- ABOUT CONTENT -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            
            <div class="col-lg-6 mb-4">
                <img src="https://cdn-icons-png.flaticon.com/512/3135/3135755.png"
                     class="img-fluid rounded-4 shadow">
            </div>

            <div class="col-lg-6">
                <h2 class="fw-bold mb-4">Biz Kimimiz?</h2>
                <p class="text-muted">
                    Learnify bu online ta’lim platformasi bo‘lib,
                    dasturlash, dizayn va zamonaviy IT yo‘nalishlarini
                    professional darajada o‘rgatadi.
                </p>

                <p class="text-muted">
                    Maqsadimiz — yoshlarni zamonaviy kasblarga o‘rgatish
                    va real loyihalar orqali tajriba berish.
                </p>

                <div class="row mt-4">
                    <div class="col-6">
                        <h3 class="fw-bold text-primary">500+</h3>
                        <p class="text-muted">Students</p>
                    </div>
                    <div class="col-6">
                        <h3 class="fw-bold text-primary">25+</h3>
                        <p class="text-muted">Courses</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- WHY US -->
<section class="py-5 bg-light">
    <div class="container text-center">
        <h2 class="fw-bold mb-5">Why Learnify?</h2>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="p-4 shadow rounded-4 bg-white h-100">
                    <h4 class="fw-bold mb-3">🎯 Real Projects</h4>
                    <p class="text-muted">
                        Amaliy loyihalar orqali tajriba orttirasiz.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 shadow rounded-4 bg-white h-100">
                    <h4 class="fw-bold mb-3">👨‍🏫 Professional Mentors</h4>
                    <p class="text-muted">
                        Tajribali ustozlar bilan ishlaysiz.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 shadow rounded-4 bg-white h-100">
                    <h4 class="fw-bold mb-3">🚀 Fast Growth</h4>
                    <p class="text-muted">
                        Tez o‘sish va real natijalar.
                    </p>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- CTA -->
<section class="py-5 text-white text-center" style="background: linear-gradient(135deg,#ff512f,#dd2476);">
    <div class="container">
        <h2 class="fw-bold mb-4">Join Learnify Today</h2>
        <a href="#" class="btn btn-light btn-lg px-5 fw-semibold">Get Started</a>
    </div>
</section>