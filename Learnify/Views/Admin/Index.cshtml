@{
    ViewData["Title"] = "Admin Dashboard";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    body { background: linear-gradient(135deg,#0f2027,#203a43,#2c5364); }
    .sidebar { min-height: 100vh; background:#1f2937; color:white; }
    .sidebar a { color:white; text-decoration:none; display:block; padding:12px; border-radius:6px; margin-bottom:5px; }
    .sidebar a:hover { background:#3b82f6; }
    .card-stat { border-radius:20px; transition: transform .2s; }
    .card-stat:hover { transform: scale(1.05); }
</style>

<div class="container-fluid">
    <div class="row">

        <!-- Sidebar -->
        <div class="col-md-2 sidebar p-3">
            <h3 class="text-center mb-4">Admin Panel</h3>
            <a href="/Admin/Index"><i class="fas fa-home me-2"></i>Dashboard</a>
            <a href="/Admin/Courses"><i class="fas fa-book me-2"></i>Courses</a>
            <a href="/Admin/Users"><i class="fas fa-users me-2"></i>Users</a>
            <a href="#"><i class="fas fa-cog me-2"></i>Settings</a>
            <a href="#"><i class="fas fa-right-from-bracket me-2"></i>Logout</a>
        </div>

        <!-- Main Content -->
        <div class="col-md-10 p-4">
            <h1 class="text-white mb-4">Welcome, Admin 🚀</h1>
            
            <div class="row g-4">

                <div class="col-md-4">
                    <div class="card card-stat text-white p-3 shadow-lg" style="background: linear-gradient(135deg,#f12711,#f5af19);">
                        <h5>Courses</h5>
                        <h2>25 Active</h2>
                        <a href="/Admin/Courses" class="text-white fw-bold">Manage Courses <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card card-stat text-white p-3 shadow-lg" style="background: linear-gradient(135deg,#11998e,#38ef7d);">
                        <h5>Students</h5>
                        <h2>500+</h2>
                        <a href="/Admin/Users" class="text-white fw-bold">Manage Users <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card card-stat text-white p-3 shadow-lg" style="background: linear-gradient(135deg,#654ea3,#eaafc8);">
                        <h5>Revenue</h5>
                        <h2>$12,500</h2>
                        <a href="#" class="text-white fw-bold">View Details <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>

            </div>

            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="card p-3 shadow-lg bg-light rounded-4">
                        <h5>Recent Courses</h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">Web Development Basics <span class="badge bg-primary float-end">120 Students</span></li>
                            <li class="list-group-item">UI/UX Design <span class="badge bg-success float-end">80 Students</span></li>
                            <li class="list-group-item">Marketing 101 <span class="badge bg-warning float-end">60 Students</span></li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card p-3 shadow-lg bg-light rounded-4">
                        <h5>Recent Users</h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">Ali Veli <span class="badge bg-primary float-end">3 Courses</span></li>
                            <li class="list-group-item">Maryam Qodirova <span class="badge bg-success float-end">2 Courses</span></li>
                            <li class="list-group-item">Jhon Smith <span class="badge bg-warning float-end">1 Course</span></li>
                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>