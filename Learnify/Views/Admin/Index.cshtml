@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="text-white mb-4 fw-bold">Admin Dashboard</h2>

<div class="row g-4">

    <!-- Courses -->
    <div class="col-md-4">
        <div class="card dashboard-card p-4 text-center">
            <div class="icon">📚</div>
            <h5 class="mt-3">Courses</h5>
            <h1>12</h1>

            <div class="progress mt-3">
                <div class="progress-bar bg-info" style="width:70%"></div>
            </div>

            <small class="text-light">Active courses</small>
        </div>
    </div>

    <!-- Students -->
    <div class="col-md-4">
        <div class="card dashboard-card p-4 text-center">
            <div class="icon">🎓</div>
            <h5 class="mt-3">Students</h5>
            <h1>150</h1>

            <div class="progress mt-3">
                <div class="progress-bar bg-success" style="width:85%"></div>
            </div>

            <small class="text-light">Registered students</small>
        </div>
    </div>

    <!-- Teachers -->
    <div class="col-md-4">
        <div class="card dashboard-card p-4 text-center">
            <div class="icon">👨‍🏫</div>
            <h5 class="mt-3">Teachers</h5>
            <h1>8</h1>

            <div class="progress mt-3">
                <div class="progress-bar bg-warning" style="width:50%"></div>
            </div>

            <small class="text-light">Active teachers</small>
        </div>
    </div>

</div>

<style>

    body {
        background: linear-gradient(135deg,#141e30,#243b55);
    }

    /* CARD */

    .dashboard-card {
        border-radius: 20px;
        backdrop-filter: blur(10px);
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        transition: all .35s ease;
        box-shadow: 0 15px 35px rgba(0,0,0,0.4);
    }

        /* hover animatsiya */

        .dashboard-card:hover {
            transform: translateY(-10px) scale(1.03);
            box-shadow: 0 25px 50px rgba(0,0,0,0.6);
        }

    /* icon */

    .icon {
        font-size: 50px;
    }

    /* progress */

    .progress {
        height: 8px;
        background: rgba(255,255,255,0.2);
        border-radius: 10px;
    }

    .progress-bar {
        border-radius: 10px;
    }

</style>