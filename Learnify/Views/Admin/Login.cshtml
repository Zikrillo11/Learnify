@{
    Layout = null;  
}

<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />  
<title>Admin Login</title>  

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">  
 
<style>    

/* 🌌 ANIMATED BACKGROUND */   
body{     
    margin:0; 
    height:100vh;
    display:flex;
    justify-content:center;    
    align-items:center;
    font-family:'Segoe UI';
    overflow:hidden;     

    background:linear-gradient(270deg,#0f2027,#203a43,#2c5364,#000000);  
    background-size:800% 800%;
    animation:bgMove 15s ease infinite;
}

@@keyframes bgMove{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

/* ✨ GLOW ORBS */
body::before, body::after{
    content:"";
    position:absolute;
    width:400px;
    height:400px;
    border-radius:50%;
    filter:blur(120px);
    opacity:0.6;
    animation:float 10s infinite alternate;
}

body::before{
    background:#00f7ff;
    top:-100px;
    left:-100px;
}

body::after{
    background:#ff00cc;
    bottom:-100px;
    right:-100px;
}

@@keyframes float{
    from{transform:translateY(0);}
    to{transform:translateY(100px);}
}

/* 💎 LOGIN BOX */
.login-box{
    width:460px;
    padding:60px;
    border-radius:25px;
    background:rgba(255,255,255,0.08);
    backdrop-filter:blur(25px);
    color:white;
    text-align:center;
    box-shadow:0 0 100px rgba(0,0,0,0.8);
    transition:0.4s;
}

.login-box:hover{
    transform:scale(1.05);
    box-shadow:0 0 120px rgba(0,255,255,0.6);
}

/* 🔥 TITLE */
.login-box h2{
    margin-bottom:30px;
    font-size:34px;
    letter-spacing:1px;    
}

/* INPUT */
.form-control{
    background:rgba(255,255,255,0.1);
    border:none;
    color:white;    
    margin-bottom:15px;
    padding:14px;   
    border-radius:10px;    
}

.form-control:focus{
    box-shadow:0 0 20px #00f7ff;  
    background:rgba(255,255,255,0.2);
    color:white;
}  
  
/* 🚀 BUTTON */
.btn-login{
    width:100%;
    padding:14px;   
    border:none;
    border-radius:12px;
    background:linear-gradient(90deg,#00f7ff,#ff00cc);
    color:white;
    font-weight:bold;
    transition:0.3s;
}

.btn-login:hover{
    transform:scale(1.05);
    box-shadow:0 0 40px #00f7ff;
}

</style> 
</head> 

<body>

<div class="login-box">
    <h2>🚀 Admin Login</h2>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form method="post" asp-controller="Admin" asp-action="Login">
        <input name="username" class="form-control" placeholder="Username" />
        <input type="password" name="password" class="form-control" placeholder="Password" />
        <button class="btn-login">Login</button>
    </form>
</div>

</body>
</html>