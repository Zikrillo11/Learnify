@{
    ViewData["Title"] = "About Us";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    body {
        background: #f4f6f9; 
    }

    .hero {
        background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
        color: white;
        padding: 120px 0;
        text-align: center;
    }

        .hero h1 {
            font-size: 60px; 
            font-weight: 800;
        }

    .glass-card {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        transition: 0.4s;
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    }

        .glass-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 25px 60px rgba(0,0,0,0.2);
        }

    .icon-big {
        font-size: 50px;
        margin-bottom: 20px;
        color: #0d6efd;
    }

    .stats {
        background: linear-gradient(135deg,#4e73df,#1cc88a);
        color: white;
        padding: 80px 0;
        text-align: center;
    }

    .team-card {
        border-radius: 20px;
        transition: 0.3s;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        padding: 30px;
        background: white;
    }

        .team-card:hover {
            transform: scale(1.05);
        }

    .cta {
        background: linear-gradient(135deg,#ff416c,#ff4b2b);
        color: white;
        padding: 100px 0;
        text-align: center;
    }

        .cta button {
            padding: 15px 40px;
            border-radius: 50px;
            border: none;
            font-weight: bold;
        }
</style>

<!-- HERO -->
<section class="hero">
    <div class="container">
        <h1>About Learnify 🚀</h1>
        <p class="lead mt-4">
            Biz zamonaviy IT o‘quv markazi bo‘lib, talabalarni real loyihalar orqali professional darajaga olib chiqamiz.
        </p>
    </div>
</section>

<!-- FEATURES -->
<section class="py-5">
    <div class="container text-center">
        <h2 class="fw-bold mb-5">Why Learnify?</h2>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="glass-card">
                    <i class="fas fa-laptop-code icon-big"></i>
                    <h4>Real Projects</h4>
                    <p>
                        Amaliy loyihalar bilan haqiqiy tajriba orttirasiz.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="glass-card">
                    <i class="fas fa-chalkboard-teacher icon-big"></i>
                    <h4>Strong Mentors</h4>
                    <p>
                        Tajribali ustozlar bilan o‘rganish imkoniyati.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="glass-card">
                    <i class="fas fa-rocket icon-big"></i>
                    <h4>Fast Growth</h4>
                    <p>
                        Qisqa vaqt ichida professional darajaga chiqasiz.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- STATS -->
<section class="stats">
    <div class="container">
        <div class="row">

            <div class="col-md-4">
                <h1 class="display-4 fw-bold">1500+</h1>
                <p>Students</p>
            </div>

            <div class="col-md-4">
                <h1 class="display-4 fw-bold">45+</h1>
                <p>Courses</p>
            </div>

            <div class="col-md-4">
                <h1 class="display-4 fw-bold">90%</h1>
                <p>Success Rate</p>
            </div>

        </div>
    </div>
</section>

<!-- TEAM -->
<section class="py-5 bg-light text-center">
    <div class="container">
        <h2 class="fw-bold mb-5">Our Professional Team 👨‍🏫</h2>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="team-card">
                    <i class="fas fa-user-tie fa-3x text-primary mb-3"></i>
                    <h5>Backend Instructor</h5>
                    <p>ASP.NET Core va Database mutaxassisi</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="team-card">
                    <i class="fas fa-user-graduate fa-3x text-success mb-3"></i>
                    <h5>Frontend Mentor</h5>
                    <p>HTML, CSS, JS va React bo‘yicha ustoz</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="team-card">
                    <i class="fas fa-user-cog fa-3x text-danger mb-3"></i>
                    <h5>Project Manager</h5>
                    <p>Real loyiha tajribasini nazorat qiladi</p>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta">
    <div class="container">
        <h2 class="fw-bold mb-3">Start Your IT Journey Today 🔥</h2>
        <p class="mb-4">
            Kelajagingizni bugundan boshlang!
        </p>
        <button class="btn btn-light">Join Now</button>
    </div>
</section>