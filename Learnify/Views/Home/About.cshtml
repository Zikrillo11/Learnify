@{
    ViewData["Title"] = "About";
}

<style>
    .hero-about {
        position: relative;
        background: url('https://images.unsplash.com/photo-1581090700227-1a5ad44b0f02') center/cover no-repeat;
        min-height: 60vh;
        display: flex;
        align-items: center;
        color: white;
    }
    .hero-about::before {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.6);
    }
    .hero-about .container {
        position: relative;
        z-index: 2;
    }

    .team-card, .testimonial-card {
        border-radius: 20px;
        box-shadow: 0 15px 30px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

    .team-card:hover, .testimonial-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 25px 45px rgba(0,0,0,0.15);
    }

    .stat-box {
        background: #0d6efd;
        color: white;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 15px 30px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

    .stat-box:hover {
        transform: scale(1.05);
    }
</style>

<!-- HERO -->
<section class="hero-about text-center">
    <div class="container py-5">
        <h1 class="display-3 fw-bold mb-3">About Learnify 🚀</h1>
        <p class="lead mb-0">Zamonaviy ta'lim platformasi — Dasturlash va IT yo'nalishlari</p>
    </div>
</section>

<!-- ABOUT CONTENT -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-lg-6">
                <h2 class="fw-bold mb-4">Biz Kimimiz?</h2>
                <p class="text-muted">
                    Learnify bu online ta’lim platformasi bo‘lib,
                    dasturlash, dizayn va zamonaviy IT yo‘nalishlarini professional darajada o‘rgatadi.
                </p>
                <p class="text-muted">
                    Maqsadimiz — yoshlarni zamonaviy kasblarga o‘rgatish
                    va real loyihalar orqali tajriba berish.
                </p>
            </div>
            <div class="col-lg-6 mb-4">
                <img src="https://cdn-icons-png.flaticon.com/512/3135/3135755.png"
                     class="img-fluid rounded-4 shadow">
            </div>
        </div>

        <!-- STATS -->
        <div class="row text-center g-4 mb-5">
            <div class="col-md-4">
                <div class="stat-box">
                    <h3 class="fw-bold">500+</h3>
                    <p>Students</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-box">
                    <h3 class="fw-bold">25+</h3>
                    <p>Courses</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-box">
                    <h3 class="fw-bold">50+</h3>
                    <p>Projects</p>
                </div>
            </div>
        </div>
    </div>
</section>

