@{
    ViewData["Title"] = "Home";
}

<style>
    .hero {
        position: relative;
        min-height: 90vh;
        background: url('https://images.unsplash.com/photo-1498050108023-c5249f4df085') center/cover no-repeat;
        display: flex;
        align-items: center;
        color: white;
    }

    .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.7);
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .blur-shape {
        position: absolute;
        width: 300px;
        height: 300px;
        background: #0d6efd;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.4;
        z-index: 1;
    }

    .shape1 { top: 10%; left: 5%; }
    .shape2 { bottom: 10%; right: 5%; background:#6610f2; }

    .feature-card {
        border-radius: 20px;
        transition: 0.3s;
        box-shadow: 0 15px 30px rgba(0,0,0,0.08);
    }

    .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 25px 45px rgba(0,0,0,0.15);
    }
</style>


<!-- HERO SECTION -->
<section class="hero text-center">
    <div class="blur-shape shape1"></div>
    <div class="blur-shape shape2"></div>

    <div class="container hero-content">
        <h1 class="display-2 fw-bold mb-4">
            Build Your IT Career 🚀
        </h1>
        <p class="lead mb-4">
            Learnify bilan zamonaviy kasblarni o‘rganing
        </p>

        <a href="/Home/Courses" class="btn btn-primary btn-lg rounded-pill px-5 me-3">
            Explore Courses
        </a>

        <a href="/Home/About" class="btn btn-outline-light btn-lg rounded-pill px-5">
            Learn More
        </a>
    </div>
</section>


<!-- FEATURES -->
<section class="py-5 bg-light">
    <div class="container text-center">
        <h2 class="fw-bold mb-5">Why Learnify?</h2>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="bg-white p-4 feature-card h-100">
                    <div class="fs-1 mb-3">🎯</div>
                    <h5 class="fw-bold">Real Projects</h5>
                    <p class="text-muted">
                        Amaliy loyihalar orqali haqiqiy tajriba.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="bg-white p-4 feature-card h-100">
                    <div class="fs-1 mb-3">👨‍🏫</div>
                    <h5 class="fw-bold">Strong Mentors</h5>
                    <p class="text-muted">
                        Tajribali ustozlar bilan ishlash.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="bg-white p-4 feature-card h-100">
                    <div class="fs-1 mb-3">🚀</div>
                    <h5 class="fw-bold">Fast Growth</h5>
                    <p class="text-muted">
                        Qisqa vaqtda professional daraja.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>


<!-- STATS -->
<section class="py-5 text-white text-center"
         style="background: linear-gradient(135deg,#0d6efd,#6610f2);">
    <div class="container">
        <div class="row">

            <div class="col-md-4">
                <h1 class="fw-bold">1500+</h1>
                <p>Students</p>
            </div>

            <div class="col-md-4">
                <h1 class="fw-bold">40+</h1>
                <p>Courses</p>
            </div>

            <div class="col-md-4">
                <h1 class="fw-bold">95%</h1>
                <p>Success Rate</p>
            </div>

        </div>
    </div>
</section>


<!-- TESTIMONIAL -->
<section class="py-5 bg-white text-center">
    <div class="container">
        <h2 class="fw-bold mb-5">What Students Say 💬</h2>

        <div class="col-lg-8 mx-auto">
            <div class="p-4 shadow rounded-4">
                <p class="text-muted">
                    “Learnify orqali backend o‘rgandim va hozir real loyihalarda ishlayapman.”
                </p>
                <h6 class="fw-bold mt-3">— Student</h6>
            </div>
        </div>
    </div>
</section>


<!-- CTA -->
<section class="py-5 text-center text-white"
         style="background: linear-gradient(135deg,#ff416c,#ff4b2b);">
    <div class="container">
        <h2 class="fw-bold mb-3">Start Your Journey Today 🔥</h2>
        <p class="mb-4 opacity-75">
            Kelajak kasbingizni bugundan boshlang
        </p>
        <a href="/Home/Contact" class="btn btn-light btn-lg rounded-pill px-5">
            Contact Us
        </a>
    </div>
</section>